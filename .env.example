# grocery_manager — copy to .env and fill in. .env is gitignored.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Password of the `grocery_app` role on the shared Postgres. MUST match
# GROCERY_DB_PASSWORD in main-server-infra/.env. Used to build DATABASE_URL.
GROCERY_DB_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────────
# Session cookie signing secret. Generate: openssl rand -hex 32
SESSION_SECRET=

# ── Imprint / privacy policy ──────────────────────────────────────────────────
# Provider details required by § 5 DDG and Art. 13 GDPR. Leave empty if you run
# the app privately — there is no imprint duty then, and the link stays hidden.
# Once you offer it commercially, these details are mandatory.
LEGAL_NAME=
LEGAL_CARE_OF=
LEGAL_STREET=
LEGAL_CITY=
LEGAL_COUNTRY=
LEGAL_EMAIL=
# Only when liable for VAT; leave empty under the small-business rule (§ 19 UStG).
LEGAL_VAT_ID=
# Named in the privacy policy as the Art. 28 GDPR processor, e.g. "Hetzner
# Online GmbH, Industriestrasse 25, 91710 Gunzenhausen, in a data centre in
# Germany".
LEGAL_HOSTING_PROVIDER=

# ── Seeded accounts (exactly 2, created on first start, argon2-hashed) ─────────
USER1_NAME=
USER1_PASSWORD=
USER1_COLOR=#3b82f6
USER2_NAME=
USER2_PASSWORD=
USER2_COLOR=#ef4444
